// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum VerificationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum CardStatus {
  ACTIVE
  USED
  EXPIRED
  INVALID
  BLOCKED
  UNKNOWN
}

// ─── Models ──────────────────────────────────────────────────────────────────

model CardType {
  id        String   @id @default(cuid())
  name      String
  brand     String
  logo      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  verificationRequests VerificationRequest[]

  @@unique([brand])
  @@map("card_types")
}

model VerificationRequest {
  id                String              @id @default(cuid())
  cardTypeId        String              @map("card_type_id")
  currency          String              @db.VarChar(3)
  amount            Decimal             @db.Decimal(12, 2)
  encryptedCardCode String              @map("encrypted_card_code")
  encryptedPin      String?             @map("encrypted_pin")
  status            VerificationStatus  @default(PENDING)
  ipAddress         String?             @map("ip_address")
  country           String?
  userAgent         String?             @map("user_agent")
  fingerprint       String?             // SHA-256 of card_type+currency+amount+card_code
  createdAt         DateTime            @default(now()) @map("created_at")

  cardType            CardType             @relation(fields: [cardTypeId], references: [id])
  verificationResult  VerificationResult?
  auditLogs           AuditLog[]

  @@index([status])
  @@index([ipAddress])
  @@index([fingerprint])
  @@index([createdAt])
  @@map("verification_requests")
}

model VerificationResult {
  id          String     @id @default(cuid())
  requestId   String     @unique @map("request_id")
  provider    String
  valid       Boolean
  balance     Decimal?   @db.Decimal(12, 2)
  currency    String?    @db.VarChar(3)
  cardStatus  CardStatus @default(UNKNOWN) @map("card_status")
  rawResponse Json?      @map("raw_response")
  verifiedAt  DateTime   @default(now()) @map("verified_at")

  request VerificationRequest @relation(fields: [requestId], references: [id])

  @@index([verifiedAt])
  @@map("verification_results")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  requestId String?  @map("request_id")
  ip        String?
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  request VerificationRequest? @relation(fields: [requestId], references: [id])

  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
